    <detaileddescription>
<para>SO2 distance functor Corresponding distance traits: <ref refid="structnanoflann_1_1metric__SO2" kindref="compound">nanoflann::metric_SO2</ref></para>
<para><parameterlist kind="templateparam"><parameteritem>
<parameternamelist>
<parametername>T</parametername>
</parameternamelist>
<parameterdescription>
<para>Type of the elements (e.g. double, float, uint8_t) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>DataSource</parametername>
</parameternamelist>
<parameterdescription>
<para>Source of the data, i.e. where the vectors are stored </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>_DistanceType</parametername>
</parameternamelist>
<parameterdescription>
<para>Type of distance variables (must be signed) (e.g. float, double) orientation is constrained to be in [-pi, pi] </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>IndexType</parametername>
</parameternamelist>
<parameterdescription>
<para>Type of the arguments with which the data can be accessed (e.g. float, double, int64_t, T*) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
