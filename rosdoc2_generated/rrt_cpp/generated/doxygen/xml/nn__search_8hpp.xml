        <type>bool</type>
        <definition>bool is_already_inserted_xy</definition>
        <argsstring>(const CoordinateSequence &amp;samples, const CoordinateXY &amp;coord, std::vector&lt; CoordinateXY &gt; &amp;X_near, CoordinateXY &amp;closest_point, const bool &amp;fill_fn_params=true, const geos_t &amp;eps_L2_squared=GP::eps_L2_squared, const geos_t &amp;delta_R_squared=GP::delta_R_squared)</argsstring>
        <name>is_already_inserted_xy</name>
        <param>
          <type>const CoordinateSequence &amp;</type>
          <declname>samples</declname>
        </param>
        <param>
          <type>const CoordinateXY &amp;</type>
          <declname>coord</declname>
        </param>
        <param>
          <type>std::vector&lt; CoordinateXY &gt; &amp;</type>
          <declname>X_near</declname>
        </param>
        <param>
          <type>CoordinateXY &amp;</type>
          <declname>closest_point</declname>
        </param>
        <param>
          <type>const bool &amp;</type>
          <declname>fill_fn_params</declname>
          <defval>true</defval>
        </param>
        <param>
          <type>const geos_t &amp;</type>
          <declname>eps_L2_squared</declname>
          <defval>GP::eps_L2_squared</defval>
        </param>
