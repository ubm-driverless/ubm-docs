        </param>
        <param>
          <type>const vector&lt; double &gt; &amp;</type>
          <declname>el_lengths</declname>
        </param>
        <param>
          <type>double</type>
          <declname>drag_coeff</declname>
        </param>
        <param>
          <type>double</type>
          <declname>m_veh</declname>
        </param>
