</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n</parametername>
</parameternamelist>
<parameterdescription>
<para>The divisor </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The modulo of the division</para>
</simplesect>
</para>
