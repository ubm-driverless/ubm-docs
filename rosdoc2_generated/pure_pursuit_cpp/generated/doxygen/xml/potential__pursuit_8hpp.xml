      <memberdef kind="function" id="potential__pursuit_8hpp_1a001992bfd72a494fa6becdefd8790409" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>std::vector&lt; std::pair&lt; unsigned short int, float &gt; &gt;</type>
        <definition>std::vector&lt;std::pair&lt;unsigned short int, float&gt; &gt; findLocalMinima</definition>
        <argsstring>(const std::vector&lt; float &gt; &amp;vec)</argsstring>
        <name>findLocalMinima</name>
        <param>
          <type>const std::vector&lt; float &gt; &amp;</type>
          <declname>vec</declname>
        </param>
        <briefdescription>
<para>Finds the local minima in a given vector. </para>
        </briefdescription>
        <detaileddescription>
<para>This function scans a vector of floats and identifies the indices of all local minima. A local minimum is defined as an element which is smaller than both its immediate neighbors. Note: The first and last elements of the vector are not considered because they don&apos;t have two neighbors.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>vec</parametername>
</parameternamelist>
<parameterdescription>
<para>The vector to scan for local minima. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>A vector of indices where each index is a position of a local minimum in the input vector. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="include/potential_pursuit.hpp" line="625" column="13" bodyfile="include/potential_pursuit.hpp" bodystart="625" bodyend="647"/>
      </memberdef>
      <memberdef kind="function" id="potential__pursuit_8hpp_1a9fcd6199c677311215ba908d8fb9322c" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>unsigned short int</type>
